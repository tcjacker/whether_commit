# Optional LLM reasoning configuration.
# Copy this file to backend/.env.reasoning.local and fill in real values locally.
# Do not commit backend/.env.reasoning.local.

OBS_REASONING_PROVIDER_ENABLED=false
OBS_REASONING_PROVIDER_NAME=openai_compatible
OBS_REASONING_MODEL=example-model
OBS_REASONING_BASE_URL=https://example.com/v1/chat/completions
OBS_REASONING_API_KEY=
OBS_REASONING_TIMEOUT_SECONDS=90
